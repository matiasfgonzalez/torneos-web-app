// Schema GOLAZO — nueva estructura (2026-07-05)
// Decisiones D1-D9 en TODO.md: multi-tenancy por Organization, roles de
// plataforma mínimos + roles por organización, categorías en 3 campos.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUARIOS Y ORGANIZACIONES
// ============================================================

// Rol de PLATAFORMA. El rol de trabajo (organizador/colaborador)
// vive en OrganizationMember.role (decisión D5).
enum UserRole {
  ADMINISTRADOR // product owner: gestiona todo
  USUARIO       // todo registrado (cliente/visitante)
}

enum UserStatus {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  PENDIENTE
}

model User {
  id            String     @id @default(uuid())
  clerkUserId   String     @unique
  email         String     @unique
  name          String?
  imageUrl      String?
  phone         String?
  location      String?
  bio           String?
  role          UserRole   @default(USUARIO)
  status        UserStatus @default(ACTIVO)
  lastLoginAt   DateTime?
  emailVerified Boolean    @default(false)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  news               News[]
  auditLogs          AuditLog[]
  ownedOrganizations Organization[]       @relation("OwnedOrganizations")
  memberships        OrganizationMember[]
  favorites          Favorite[]
  // Equipos que representa como delegado (N13). Es un eje distinto de
  // `memberships`: el delegado no trabaja para la liga, representa a un equipo.
  teamManagerships   TeamManager[]
  teamManagerDecisions TeamManager[]      @relation("TeamManagerDecisions")
  playersCreated     Player[]             @relation("PlayersCreated")
  // Ficha de jugador que esta persona reclama como propia (N12)
  playerClaims         PlayerClaim[]
  playerClaimDecisions PlayerClaim[]      @relation("PlayerClaimDecisions")
  // Notificaciones y sus preferencias (S5)
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  @@index([role, status])
}

enum OrgStatus {
  ACTIVA
  SUSPENDIDA // por falta de pago o abuso
}

// Rol DENTRO de una organización (decisión D5)
enum OrgRole {
  OWNER       // creó la liga; gestiona plan, pagos y miembros
  ORGANIZADOR // gestión completa de torneos/equipos/jugadores/partidos
  COLABORADOR // solo carga de resultados/eventos (planilleros)
}

model Organization {
  id           String    @id @default(uuid())
  name         String // "Liga Municipal de Rafaela"
  slug         String    @unique // /liga/[slug]
  logoUrl      String?
  logoPublicId String?
  description  String?
  locality     String?
  phone        String? // contacto público (WhatsApp)
  status       OrgStatus @default(ACTIVA)

  ownerId String
  owner   User   @relation("OwnedOrganizations", fields: [ownerId], references: [id])

  members     OrganizationMember[]
  invites     OrganizationInvite[]
  tournaments Tournament[]
  teams       Team[]
  // `players` se eliminó: la ficha de jugador es global (N12), no de una liga.
  // Los jugadores de una liga se derivan de la participación en sus torneos.
  referees     Referee[]
  subscription Subscription?
  orgPosts     OrgPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Novedad de la liga (S12) — publicación del organizador en su página pública
 * `/liga/[slug]`. NO reusa `News` (que es contenido de plataforma, solo ADMIN):
 * esto es contenido por organización, gateado por la feature de plan `orgNews`.
 * `publishedAt` es nullable y se setea al publicar (no `@default(now())`, que
 * daría un orden de publicación falso a los borradores — bug conocido de News).
 */
model OrgPost {
  id                 String    @id @default(uuid())
  title              String
  summary            String?
  content            String
  coverImageUrl      String?
  coverImagePublicId String?
  published          Boolean   @default(false)
  publishedAt        DateTime?
  deletedAt          DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, published, publishedAt])
}

// ============================================================
// PLANES Y PAGOS (N4/N5 — freemium D7, pagos manuales D8)
// ============================================================

model Plan {
  id                    String  @id @default(uuid())
  code                  String  @unique // FREE | PRO | PREMIUM
  name                  String
  priceMonthly          Decimal @db.Decimal(10, 2)
  currency              String  @default("ARS")
  maxActiveTournaments  Int
  maxTeamsPerTournament Int
  maxMembers            Int
  // Flags: { "exportPdf": bool, "customBranding": bool, "liveMatch": bool }
  features              Json
  isActive              Boolean @default(true)
  order                 Int     @default(0)

  subscriptions Subscription[]
}

enum SubStatus {
  ACTIVA
  VENCIDA // pasó currentPeriodEnd → límites de FREE (nunca se ocultan datos)
  CANCELADA
}

model Subscription {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status           SubStatus @default(ACTIVA)
  currentPeriodEnd DateTime? // null = FREE sin vencimiento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
}

enum PayMethod {
  TRANSFERENCIA
  EFECTIVO
  MERCADOPAGO // futuro: webhook crea el Payment aprobado con externalId
}

enum PayStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

model Payment {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Plan que se está pagando (puede diferir del plan actual = upgrade)
  planId String?

  amount       Decimal   @db.Decimal(10, 2)
  currency     String    @default("ARS")
  periodMonths Int       @default(1)
  method       PayMethod
  status       PayStatus @default(PENDIENTE)

  receiptUrl      String? // comprobante (Cloudinary: pagos/comprobantes)
  receiptPublicId String?
  externalId      String? // ID de Mercado Pago cuando exista
  notes           String? // nota del organizador
  reviewNotes     String? // motivo de rechazo del admin
  reviewedById    String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([subscriptionId])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        OrgRole
  invitedById String?
  createdAt   DateTime @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

enum InviteStatus {
  PENDIENTE
  ACEPTADA
  CANCELADA
}

// Invitación a una organización por email (N6). Si el email ya tiene
// cuenta se crea la membresía directo; si no, queda PENDIENTE y se
// acepta automáticamente cuando esa persona se registra e ingresa.
model OrganizationInvite {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email       String // normalizado a minúsculas
  role        OrgRole // ORGANIZADOR | COLABORADOR (nunca OWNER)
  status      InviteStatus @default(PENDIENTE)
  invitedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([email, status])
}

// ============================================================
// NOTICIAS (globales de la plataforma — solo ADMINISTRADOR)
// ============================================================

model News {
  id                 String    @id @default(uuid())
  title              String
  summary            String?
  content            String
  coverImageUrl      String?
  coverImagePublicId String?
  published          Boolean   @default(false)
  publishedAt        DateTime  @default(now())
  deletedAt          DateTime?
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([published, publishedAt])
}

// ============================================================
// TORNEOS
// ============================================================

enum TournamentStatus {
  BORRADOR
  INSCRIPCION
  PENDIENTE
  ACTIVO
  SUSPENDIDO
  FINALIZADO
  CANCELADO
  ARCHIVADO
}

// Categoría separada en 3 campos (decisión M13):
// ageGroup + gender + division ("Sub-17 Femenino A")
enum AgeGroup {
  LIBRE
  ESCUELITA
  MINI
  INFANTIL
  JUVENIL
  SUB_17
  SUB_20
  SENIOR
  M30
  VETERANO
  PREVETERANO
  SUPERVETERANO
  MASTER
}

enum Gender {
  MASCULINO
  FEMENINO
  MIXTO
}

enum TournamentFormat {
  LIGA
  COPA
  ELIMINACION_DIRECTA
  DOBLE_ELIMINACION
  GRUPOS
  IDA_Y_VUELTA
  ROUND_ROBIN
  SUIZO
  MIXTO
  PLAYOFFS
  LIGUILLA
  TODOS_CONTRA_TODOS
  PUNTOS_ACUMULADOS
  AMISTOSO
}

model Tournament {
  id           String             @id @default(uuid())
  name         String
  slug         String? // URL pública /liga/[orgSlug]/[slug] (N9); único por organización
  description  String?
  ageGroup     AgeGroup           @default(LIBRE)
  gender       Gender             @default(MASCULINO)
  division     String? // "A", "Primera", etc.
  locality     String
  logoUrl      String?
  logoPublicId String?
  liga         String? // nombre de liga/asociación (texto libre)
  status       TournamentStatus   @default(PENDIENTE)
  format       TournamentFormat   @default(LIGA)
  nextMatch    DateTime?
  homeAndAway  Boolean            @default(false)
  enabled      Boolean            @default(true)
  rules        String?
  trophy       String?
  deletedAt    DateTime?

  /// Cupo de equipos (S3). `null` = sin límite propio del torneo (igual manda
  /// el límite del plan de la liga, que es otra cosa: este lo elige el
  /// organizador, aquel lo impone la plataforma).
  maxTeams Int?

  /// Última fecha para pedir inscripción (S3). `null` = sin fecha límite: se
  /// cierra a mano cambiando el estado del torneo.
  registrationDeadline DateTime?

  // Configuración deportiva (N7): reglas de puntaje y desempate por torneo.
  // Habilita multi-deporte a futuro (básquet/vóley solo cambian estos valores).
  pointsWin     Int  @default(3)
  pointsDraw    Int  @default(1)
  pointsLoss    Int  @default(0)
  // Marcador que se asigna al ganador en un WALKOVER (perdedor 0)
  walkoverScore Int  @default(3)
  // Orden de criterios de desempate. Array de códigos: PTS, DIF, GF, GA, WINS.
  // null = orden por defecto ["PTS","DIF","GF","WINS"].
  tiebreakers   Json?
  // Sanciones automáticas (N8): amarillas acumuladas que gatillan una fecha
  // de suspensión, y fechas de suspensión por cada roja. 0 = desactivado.
  yellowsForSuspension Int @default(5)
  matchesPerRedCard    Int @default(1)

  startDate DateTime
  endDate   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches          Match[]
  tournamentTeams  TournamentTeam[]
  tournamentPhases TournamentPhase[]
  suspensions      Suspension[]
  favoritedBy      Favorite[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status, deletedAt])
}

enum PhaseType {
  LEAGUE   // liga/todos contra todos (suma puntos)
  GROUP    // fase de grupos (suma puntos)
  KNOCKOUT // eliminación directa (NO suma puntos a la tabla general)
}

model TournamentPhase {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  name  String // "Fase de Grupos", "Playoffs", "Apertura"
  order Int
  type  PhaseType

  matches   Match[]
  teamStats TeamPhaseStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
}

// ============================================================
// EQUIPOS Y JUGADORES
// ============================================================

model Team {
  id           String    @id @default(uuid())
  name         String
  shortName    String?
  description  String?
  history      String?
  coach        String?
  homeCity     String?
  yearFounded  Int?
  homeColor    String?
  awayColor    String?
  logoUrl      String?
  logoPublicId String?
  enabled      Boolean   @default(true)
  deletedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournamentTeams TournamentTeam[]
  favoritedBy     Favorite[]
  managers        TeamManager[]

  @@index([organizationId])
}

/// Estado de una solicitud que alguien tiene que aprobar. Compartido por los
/// dos flujos de aprobación: delegado de equipo (`TeamManager`, N13) y
/// jugador reclamando su ficha (`PlayerClaim`, N12) — mismo vocabulario para el
/// mismo concepto.
enum ApprovalStatus {
  PENDIENTE // esperando que alguien la resuelva
  APROBADO
  RECHAZADO
}

// Delegado de equipo (N13). Es la figura que representa a UN equipo: carga su
// plantel y lo inscribe en torneos (S3).
//
// **No es `OrganizationMember` a propósito.** Los roles de `OrgRole` son
// personal de la liga, y todas las consultas del panel se acotan por
// organización (`getPanelOrgIds`): si el delegado fuera miembro, vería todos
// los equipos y jugadores de la liga entera. Colgando del equipo, el
// aislamiento sale solo — `getPanelOrgIds()` le devuelve [].
//
// La liga siempre aprueba: sin eso, cualquiera se declara delegado de cualquier
// equipo.
model TeamManager {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  status ApprovalStatus @default(PENDIENTE)

  /// Mensaje del solicitante ("soy el DT desde 2019") para que la liga decida.
  message String?

  /// Quién resolvió la solicitud y cuándo (auditoría de la decisión).
  decidedById String?
  decidedBy   User?     @relation("TeamManagerDecisions", fields: [decidedById], references: [id])
  decidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Una sola solicitud por persona y equipo: reintentar actualiza la existente
  @@unique([userId, teamId])
  @@index([teamId, status])
  @@index([userId])
}

enum Foot {
  IZQUIERDA
  DERECHA
  AMBOS
}

enum PlayerStatus {
  ACTIVO
  LESIONADO
  SUSPENDIDO
  NO_DISPONIBLE
  RETIRADO
  TRANSFERIDO
  PRUEBA
  EXPULSADO
}

enum PlayerPosition {
  ARQUERO
  DEFENSOR_CENTRAL
  LATERAL_DERECHO
  LATERAL_IZQUIERDO
  CARRILERO_DERECHO
  CARRILERO_IZQUIERDO
  VOLANTE_DEFENSIVO
  PIVOTE
  VOLANTE_CENTRAL
  VOLANTE_OFENSIVO
  INTERIOR_DERECHO
  INTERIOR_IZQUIERDO
  ENGANCHE
  EXTREMO_DERECHO
  EXTREMO_IZQUIERDO
  DELANTERO_CENTRO
  SEGUNDO_DELANTERO
  FALSO_9
}

/// Ficha de jugador — **identidad global de la plataforma** (N12, decisión del
/// product owner 2026-07-14).
///
/// Antes el jugador pertenecía a una liga (`organizationId` + unique por
/// `[organizationId, nationalId]`), así que la misma persona jugando en dos
/// ligas eran dos fichas. Ahora hay **una sola ficha por persona**, identificada
/// por su DNI, y `TeamPlayer` la ata a cada `TournamentTeam`: el mismo jugador
/// puede estar en varios torneos (en el mismo equipo o en otro), pero nunca dos
/// veces en el mismo torneo.
///
/// Consecuencia: la ficha **no tiene dueño**. Qué jugadores ve una liga se
/// deriva de la participación (`TeamPlayer → TournamentTeam → Tournament`), no
/// de un `organizationId`. Toda edición queda registrada en `AuditLog`.
model Player {
  id   String @id @default(uuid())
  name String
  /// DNI — **la clave de identidad**. Obligatorio y único en toda la
  /// plataforma: es lo que evita que dos delegados carguen a la misma persona.
  nationalId String @unique
  birthDate         DateTime?
  birthPlace        String?
  nationality       String?
  height            Float?
  weight            Float?
  dominantFoot      Foot?
  position          PlayerPosition?
  number            Int?
  imageUrl          String?
  imagePublicId     String?
  imageUrlFace      String?
  imageFacePublicId String?
  description       String?
  bio               String?
  status            PlayerStatus    @default(ACTIVO)
  // Baja lógica: el jugador se sigue viendo (y conserva su historial de goles,
  // tarjetas y sanciones) pero deja de estar disponible para sumarlo a un
  // equipo. El borrado físico solo se permite si no tiene ningún TeamPlayer.
  enabled           Boolean         @default(true)
  joinedAt          DateTime?
  deletedAt         DateTime?

  instagramUrl String?
  twitterUrl   String?

  /// Quién dio de alta la ficha. Es solo trazabilidad: **no da propiedad ni
  /// acota visibilidad** (la ficha es global). Quién puede editarla se resuelve
  /// por participación — ver `lib/playerAuth.ts`.
  createdById String?
  createdBy   User?   @relation("PlayersCreated", fields: [createdById], references: [id])

  teamPlayer TeamPlayer[]
  claims     PlayerClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // El unique de `nationalId` está en el campo: es global, no por liga.
  @@index([name])
}

/// El jugador reclama su propia ficha (N12).
///
/// La ficha la carga un delegado o la liga; el jugador después pide ser su
/// dueño para ver sus estadísticas de todas las ligas y gestionar sus datos.
///
/// **Lo aprueba quien es responsable de la ficha** — el mismo criterio que
/// `canEditPlayer`: la liga donde el jugador juega, el delegado que lo tiene en
/// su plantel, o quien la cargó. Es la gente que puede reconocerlo; la
/// plataforma no tiene forma de verificar que ese usuario es esa persona.
///
/// Una ficha puede tener a lo sumo **un** reclamo APROBADO. Postgres no permite
/// un índice único parcial desde Prisma, así que la regla se valida en el
/// server (`approvePlayerClaim`).
model PlayerClaim {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status ApprovalStatus @default(PENDIENTE)

  /// Con qué prueba el usuario que es esa persona ("mi fecha de nacimiento es…").
  message String?

  decidedById String?
  decidedBy   User?     @relation("PlayerClaimDecisions", fields: [decidedById], references: [id])
  decidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, playerId])
  @@index([playerId, status])
  @@index([userId])
}

// ============================================================
// PARTIDOS
// ============================================================

enum MatchStatus {
  PROGRAMADO
  EN_JUEGO
  ENTRETIEMPO
  FINALIZADO
  SUSPENDIDO
  POSTERGADO
  CANCELADO
  WALKOVER
}

model Match {
  id          String      @id @default(uuid())
  dateTime    DateTime
  stadium     String?
  city        String?
  description String?
  status      MatchStatus @default(PROGRAMADO)

  homeScore Int?
  awayScore Int?

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  homeTeamId String
  homeTeam   TournamentTeam @relation("HomeMatches", fields: [homeTeamId], references: [id])

  awayTeamId String
  awayTeam   TournamentTeam @relation("AwayMatches", fields: [awayTeamId], references: [id])

  goals    Goal[]
  cards    Card[]
  referees MatchReferee[]

  penaltyWinnerTeamId String?
  penaltyWinnerTeam   TournamentTeam? @relation("PenaltyWinner", fields: [penaltyWinnerTeamId], references: [id])
  penaltyScoreHome    Int?
  penaltyScoreAway    Int?

  // WALKOVER (N7): el organizador marca el ganador y el server fija el
  // marcador (walkoverScore-0). status pasa a WALKOVER automáticamente.
  walkoverWinnerTeamId String?
  walkoverWinnerTeam   TournamentTeam? @relation("WalkoverWinner", fields: [walkoverWinnerTeamId], references: [id])

  roundNumber Int?

  tournamentPhaseId String?
  tournamentPhase   TournamentPhase? @relation(fields: [tournamentPhaseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId, dateTime])
  @@index([status])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([tournamentPhaseId])
}

model Goal {
  id        String  @id @default(uuid())
  minute    Int?
  isOwnGoal Boolean @default(false)
  isPenalty Boolean @default(false)

  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  teamPlayerId String
  teamPlayer   TeamPlayer @relation(fields: [teamPlayerId], references: [id], onDelete: Cascade)

  // Asistencia (opcional)
  assistTeamPlayerId String?
  assistTeamPlayer   TeamPlayer? @relation("Assists", fields: [assistTeamPlayerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teamPlayerId])
}

enum CardType {
  AMARILLA
  ROJA
}

model Card {
  id      String @id @default(uuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  teamPlayerId String
  teamPlayer   TeamPlayer @relation(fields: [teamPlayerId], references: [id], onDelete: Cascade)

  type   CardType
  minute Int?
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teamPlayerId])
}

// ============================================================
// EQUIPO-EN-TORNEO Y PLANTELES
// ============================================================

enum RegistrationStatus {
  INSCRIPTO // default: cargado por el organizador
  PENDIENTE // inscripción online esperando aprobación (S3)
  RECHAZADO
}

model TournamentTeam {
  id String @id @default(uuid())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  group              String?
  isEliminated       Boolean?
  notes              String?
  registrationStatus RegistrationStatus @default(INSCRIPTO)

  // Stats globales acumuladas (tabla de posiciones)
  matchesPlayed  Int @default(0)
  wins           Int @default(0)
  draws          Int @default(0)
  losses         Int @default(0)
  goalsFor       Int @default(0)
  goalsAgainst   Int @default(0)
  goalDifference Int @default(0)
  points         Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeMatches  Match[] @relation("HomeMatches")
  awayMatches  Match[] @relation("AwayMatches")
  penaltyWins  Match[] @relation("PenaltyWinner")
  walkoverWins Match[] @relation("WalkoverWinner")

  teamPlayer TeamPlayer[]
  phaseStats TeamPhaseStats[]

  @@unique([tournamentId, teamId])
  @@index([teamId])
}

model TeamPhaseStats {
  id String @id @default(uuid())

  tournamentTeamId String
  tournamentTeam   TournamentTeam @relation(fields: [tournamentTeamId], references: [id], onDelete: Cascade)

  tournamentPhaseId String
  tournamentPhase   TournamentPhase @relation(fields: [tournamentPhaseId], references: [id], onDelete: Cascade)

  groupId String?

  matchesPlayed  Int @default(0)
  wins           Int @default(0)
  draws          Int @default(0)
  losses         Int @default(0)
  goalsFor       Int @default(0)
  goalsAgainst   Int @default(0)
  goalDifference Int @default(0)
  points         Int @default(0)

  bonusPoints Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([tournamentTeamId, tournamentPhaseId])
  @@index([tournamentPhaseId])
}

model TeamPlayer {
  id String @id @default(uuid())

  tournamentTeamId String
  tournamentTeam   TournamentTeam @relation(fields: [tournamentTeamId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  position  String?
  number    Int?
  isCaptain Boolean      @default(false)
  status    PlayerStatus @default(ACTIVO)

  goals       Goal[]
  assists     Goal[]       @relation("Assists")
  cards       Card[]
  suspensions Suspension[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, tournamentTeamId])
  @@index([tournamentTeamId])
  @@index([playerId])
}

// ============================================================
// SANCIONES / SUSPENSIONES (N8)
// ============================================================

enum SuspensionReason {
  ACUMULACION // amarillas acumuladas (múltiplo de yellowsForSuspension)
  ROJA        // roja directa o doble amarilla
  MANUAL      // impuesta por el organizador
}

// Suspensión de un jugador en un torneo. Las de tipo ACUMULACION/ROJA las
// genera y reconcilia el motor (idempotente, ver lib/suspensions); las MANUAL
// las crea el organizador y nunca se borran automáticamente.
model Suspension {
  id String @id @default(uuid())

  teamPlayerId String
  teamPlayer   TeamPlayer @relation(fields: [teamPlayerId], references: [id], onDelete: Cascade)

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  reason        SuspensionReason
  totalMatches  Int // cuántas fechas dura
  servedMatches Int              @default(0) // derivado: fechas ya cumplidas
  isActive      Boolean          @default(true)

  // Fecha del evento que la originó; se cumplen los partidos posteriores del equipo
  triggerDate DateTime
  notes       String?

  // Claves de deduplicación del motor (null en MANUAL):
  sourceCardId      String? @unique // ROJA: tarjeta origen (1:1)
  accumulationIndex Int? // ACUMULACION: 1=primer múltiplo, 2=segundo...

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamPlayerId, accumulationIndex])
  @@index([tournamentId, isActive])
  @@index([teamPlayerId])
}

// ============================================================
// ÁRBITROS
// ============================================================

enum RefereeStatus {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  RETIRADO
}

model Referee {
  id                 String        @id @default(uuid())
  name               String
  email              String?
  phone              String?
  nationalId         String?
  birthDate          DateTime?
  nationality        String?
  imageUrl           String?
  certificationLevel String?
  status             RefereeStatus @default(ACTIVO)
  enabled            Boolean       @default(true)
  deletedAt          DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  matches MatchReferee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model MatchReferee {
  id      String @id @default(uuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  refereeId String
  referee   Referee @relation(fields: [refereeId], references: [id], onDelete: Cascade)

  role String // "Principal", "Juez de Línea", "VAR", "Cuarto Árbitro"

  @@unique([matchId, refereeId])
}

// ============================================================
// FAVORITOS (N10 — torneos/equipos seguidos por un USUARIO)
// ============================================================

/**
 * Un USUARIO puede seguir un torneo o un equipo (exactamente uno de los dos
 * FK, validado en la capa de app — ver modules/favoritos/actions/favorites.ts).
 * Los @@unique con columna nullable no chocan entre sí: Postgres no
 * considera dos NULL iguales, así que cada constraint solo restringe
 * duplicados dentro de su propio tipo (torneo vs equipo).
 */
model Favorite {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tournamentId])
  @@unique([userId, teamId])
  @@index([userId])
}

// ============================================================
// NOTIFICACIONES (S5)
// ============================================================

/// Qué le pasó al usuario. El texto NO vive acá: lo arma
/// `renderNotification()` en lib/notifications/catalog.ts a partir del tipo +
/// sus datos. Así un cambio de redacción no necesita migración ni reescribe
/// las notificaciones viejas.
enum NotificationType {
  // Al delegado (N13/S3)
  SOLICITUD_DELEGADO_APROBADA
  SOLICITUD_DELEGADO_RECHAZADA
  INSCRIPCION_APROBADA
  INSCRIPCION_RECHAZADA
  RESULTADO_CARGADO
  JUGADOR_SUSPENDIDO

  // A la liga (organizadores/OWNER)
  SOLICITUD_DELEGADO_RECIBIDA
  INSCRIPCION_RECIBIDA
  PAGO_APROBADO
  PAGO_RECHAZADO

  // A la plataforma (ADMINISTRADOR)
  PAGO_INFORMADO
  FICHA_DISPUTA_ABIERTA

  // Al jugador (N12/N14b)
  FICHA_APROBADA
  FICHA_RECHAZADA
}

/// Eje de las preferencias. Se agrupa por **tema que le importa al usuario**,
/// no por destinatario: nadie quiere apagar "las notificaciones de la liga",
/// quiere apagar "los mails de pagos".
enum NotificationCategory {
  EQUIPO  // delegación e inscripciones
  PARTIDO // resultados y suspensiones
  PAGO    // plan y pagos
  FICHA   // reclamos de ficha de jugador
}

/// Notificación in-app. `title`/`body`/`url` se guardan **renderizados**: la
/// campana se lee mucho más de lo que se escribe, y resolverlos en cada lectura
/// obligaría a consultar equipos/torneos que quizá ya no existen.
model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     NotificationType
  category NotificationCategory

  title String
  body  String?
  /// Adónde lleva el click. Null = no hay nada que abrir.
  url   String?

  readAt DateTime?

  /// Cuándo salió el email. Null = no se mandó (preferencia apagada, sin
  /// RESEND_API_KEY, o falló). Es el registro de qué pasó realmente, no la
  /// intención — sirve para no reintentar a ciegas.
  emailSentAt DateTime?

  createdAt DateTime @default(now())

  // La campana pregunta siempre lo mismo: no leídas de este usuario.
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// Preferencia por usuario y categoría (S5). **La ausencia de fila significa
/// todo encendido**: nadie tiene que configurar nada para que funcione, y no
/// hay que crear filas al registrar un usuario ni backfillear a los existentes.
model NotificationPreference {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category NotificationCategory

  /// La campana no se apaga (es gratis y no molesta); el email sí. Se deja el
  /// campo igual porque el día que se apague, apagarlo es una fila, no una
  /// migración.
  inApp Boolean @default(true)
  email Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@unique([userId, category])
}

// ============================================================
// CONFIGURACIÓN DEL SITIO
// ============================================================

/**
 * Fila única (singleton, id fijo "main") con la información pública del
 * sitio que el ADMINISTRADOR puede editar sin redeploy: contacto y redes
 * mostrados en el Footer. Ver getOrCreateSiteSettings() en
 * modules/configuracion/actions/siteSettings.ts.
 */
model SiteSettings {
  id String @id @default("main")

  description  String? // tagline corta del footer
  contactEmail String?
  contactPhone String?
  address      String?

  facebookUrl  String?
  twitterUrl   String?
  instagramUrl String?

  // Datos de cobro para pagos manuales (N5): el organizador transfiere a esto
  // y sube el comprobante. Los edita el ADMINISTRADOR en /admin/configuracion.
  paymentAlias        String? // alias / CBU / CVU al que se transfiere
  paymentHolder       String? // titular de la cuenta (para verificar)
  paymentInstructions String? // nota libre (ej: "poné el nombre de tu liga en el concepto")

  updatedAt DateTime @updatedAt
}

// ============================================================
// AUDITORÍA
// ============================================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}
