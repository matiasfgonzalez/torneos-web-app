# Plantilla de variables de entorno de GOLAZO.
# Copiala a `.env` y completá los valores: `cp .env.example .env`
#
# `.env` está en .gitignore; este archivo NO — así que nunca pongas acá un
# valor real, ni siquiera recortado (un prefijo de secreto también es una pista).
#
# Cada variable está documentada en el README, sección "Variables de entorno".

# ============ BASE DE DATOS (obligatoria) ============
# PostgreSQL. Sin esto la app no arranca: es la única variable sin la que
# absolutamente nada funciona.
DATABASE_URL="postgresql://usuario:clave@host:5432/basededatos?sslmode=require"

# ============ AUTENTICACIÓN — CLERK (obligatoria) ============
# Claves del dashboard de Clerk (Developers → API keys). Sin ellas no se puede
# iniciar sesión y todo `/admin` queda inaccesible.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_reemplazar
CLERK_SECRET_KEY=sk_test_reemplazar

# Rutas de la propia app (no son secretos). Estos valores son los correctos:
# cambiarlos solo si se mueven las páginas de login/registro.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Email que recibe el rol ADMINISTRADOR al iniciar sesión (bootstrap del admin,
# ver lib/checkUser.ts). Se compara sin distinguir mayúsculas, y se aplica
# también si el usuario ya existía sin el rol.
# ⚠️ Sin esto NADIE es administrador: no hay forma de entrar a la gestión de
# planes, usuarios ni organizaciones. Es lo primero que hay que configurar en
# una instalación nueva.
ADMIN_EMAIL=vos@tudominio.com

# Firma del webhook de Clerk (Dashboard → Webhooks → Signing Secret).
# Mantiene sincronizados usuario, email, foto y último login con la BD.
# Opcional en desarrollo: sin esto la app anda, pero `lastLoginAt` y los datos
# que cambien en Clerk no se reflejan en la base.
CLERK_WEBHOOK_SECRET=whsec_reemplazar

# ============ IMÁGENES — CLOUDINARY (obligatoria si se suben imágenes) ============
# Las tres son solo server-side: el API Secret NUNCA se expone al navegador.
# Sin estas variables no se pueden subir escudos, fotos ni portadas.
#
# No hace falta una `NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME`: el navegador recibe el
# cloud name en la respuesta del endpoint de firma (`/api/cloudinary/sign`),
# no de una variable propia.
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=reemplazar
CLOUDINARY_API_SECRET=reemplazar

# ============ NOTIFICACIONES POR EMAIL — RESEND (opcional, S5) ============
# TODO ESTO ES OPCIONAL: sin `RESEND_API_KEY` no se manda ningún mail y la
# campana dentro de la app sigue funcionando igual (ver lib/notifications/email.ts).
RESEND_API_KEY=re_reemplazar
# Remitente. Tiene que ser un dominio verificado en Resend.
# Sin configurar usa onboarding@resend.dev, que solo entrega a tu propia casilla.
RESEND_FROM="GOLAZO <avisos@tudominio.com>"

# ============ URL PÚBLICA (opcional) ============
# Base absoluta para links de email, imágenes OG, QR y sitemap: un mail o un QR
# no pueden usar rutas relativas.
# En Vercel se deduce sola de VERCEL_URL; en local, sin esto, asume
# http://localhost:3000. Configurala en producción con el dominio real.
NEXT_PUBLIC_APP_URL=https://tudominio.com
