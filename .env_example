NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Cloudinary Configuration
# NEXT_PUBLIC_ = Seguro exponer al cliente (solo cloud name)
# Sin prefijo = Solo server-side (API Secret NUNCA exponer)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dp0r...
CLOUDINARY_CLOUD_NAME=dp0r...
CLOUDINARY_API_KEY=629887...
CLOUDINARY_API_SECRET=qvulEykd1hDd...

# Signing Secret Clerk WEBHOOK
CLERK_WEBHOOK_SECRET=whsec_o...

# ============ NOTIFICACIONES (S5) ============
# Email vía Resend. TODO ESTO ES OPCIONAL: sin RESEND_API_KEY no se manda
# ningún mail y la campana in-app funciona igual (ver lib/notifications/email.ts).
RESEND_API_KEY=re_...
# Remitente. Debe ser un dominio verificado en Resend.
# Sin configurar usa onboarding@resend.dev, que solo entrega a tu propia casilla.
RESEND_FROM="GOLAZO <avisos@tudominio.com>"

# URL base para los links de los emails (un mail no puede usar rutas relativas).
